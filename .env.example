# GEMINI_API_KEY: Obrigatório para chamadas à API Gemini AI.
# Configure esta variável no painel do Vercel:
# Project Settings → Environment Variables → Add New
GEMINI_API_KEY="SUA_GEMINI_API_KEY"

# APP_URL: A URL onde este app está hospedado.
# No Vercel, a URL é fornecida automaticamente via VERCEL_URL.
# Esta variável é opcional — configure se precisar de uma URL personalizada.
# APP_URL="https://seu-projeto.vercel.app"

# Configurações do Supabase
NEXT_PUBLIC_SUPABASE_URL="SUA_URL_DO_SUPABASE"
NEXT_PUBLIC_SUPABASE_ANON_KEY="SUA_ANON_KEY_DO_SUPABASE"
SUPABASE_SERVICE_ROLE_KEY="SUA_SERVICE_ROLE_KEY_DO_SUPABASE"

# Configurações do LytronPay
LYTRON_API_KEY="pk_live_..."
LYTRON_API_SECRET="sk_live_..."
