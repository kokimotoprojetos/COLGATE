# GEMINI_API_KEY: Obrigatório para chamadas à API Gemini AI.
# Configure esta variável no painel do Vercel:
# Project Settings → Environment Variables → Add New
GEMINI_API_KEY="SUA_GEMINI_API_KEY"

# NEXT_PUBLIC_APP_URL: URL pública do app (usada nos links de afiliado).
# Obrigatória para que os links de convite funcionem com seu domínio correto.
NEXT_PUBLIC_APP_URL="https://www.colgates.online"

# Configurações do Supabase
NEXT_PUBLIC_SUPABASE_URL="SUA_URL_DO_SUPABASE"
NEXT_PUBLIC_SUPABASE_ANON_KEY="SUA_ANON_KEY_DO_SUPABASE"
SUPABASE_SERVICE_ROLE_KEY="SUA_SERVICE_ROLE_KEY_DO_SUPABASE"

# Configurações do LytronPay
LYTRON_API_KEY="pk_live_..."
LYTRON_API_SECRET="sk_live_..."

# Credenciais do Painel Admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="colgate2026admin"
# Token usado para autenticar chamadas ao endpoint /api/admin via header Authorization
# Gere um valor aleatório (ex.: openssl rand -hex 32) e coloque aqui.
ADMIN_TOKEN="YOUR_RANDOM_ADMIN_TOKEN_HERE"
